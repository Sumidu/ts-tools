#!/usr/bin/env bash
# download-ts — Download a numbered sequence of .ts files
# Usage: download-ts [--auto] <url-of-first-file> [output-directory]

set -euo pipefail

# ── Colours ────────────────────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
RESET='\033[0m'

info()    { echo -e "${CYAN}▸${RESET} $*"; }
success() { echo -e "${GREEN}✔${RESET} $*"; }
warn()    { echo -e "${YELLOW}⚠${RESET}  $*"; }
error()   { echo -e "${RED}✖${RESET}  $*" >&2; }
header()  { echo -e "\n${BOLD}${BLUE}$*${RESET}"; }
divider() { echo -e "${DIM}─────────────────────────────────────────${RESET}"; }

# ── Dependency check ───────────────────────────────────────────────────────
if ! command -v curl &>/dev/null; then
  error "curl not found."
  exit 1
fi

# ── Parse flags ───────────────────────────────────────────────────────────
AUTO=0
args=()
for arg in "$@"; do
  if [[ "$arg" == "--auto" ]]; then
    AUTO=1
  else
    args+=("$arg")
  fi
done
set -- "${args[@]+"${args[@]}"}"

# ── Get URL (argument or interactive prompt) ──────────────────────────────
if [[ $# -ge 1 ]]; then
  FIRST_URL="$1"
else
  header "⬇️   download-ts"
  divider
  printf "URL of first .ts file: "
  read -r FIRST_URL
  FIRST_URL="${FIRST_URL// /}"
  if [[ -z "$FIRST_URL" ]]; then
    error "No URL provided."
    exit 1
  fi
fi

OUTPUT_DIR="${2:-$HOME/Downloads}"
OUTPUT_DIR="${OUTPUT_DIR/#\~/$HOME}"

# ── Validate URL ───────────────────────────────────────────────────────────
if [[ ! "$FIRST_URL" =~ ^https?:// ]]; then
  error "URL must start with http:// or https://"
  usage
fi

# ── Parse the URL into components ──────────────────────────────────────────
# We need to find the numeric sequence part in the filename.
# e.g. https://cdn.example.com/path/to/show_003.ts
#       base  = https://cdn.example.com/path/to/
#       stem  = show_003
#       num   = 003  (we capture leading zeros → padding width)
#       ext   = .ts
#       prefix_part = show_   (everything before the number in the stem)

filename="$(basename "$FIRST_URL")"          # show_003.ts
ext=".${filename##*.}"                        # .ts
stem="${filename%.*}"                         # show_003
base_url="${FIRST_URL%/*}/"                   # https://.../

# Extract the trailing number from the stem (with possible separator)
if [[ "$stem" =~ ^(.*[^0-9])([0-9]+)$ ]]; then
  name_prefix="${BASH_REMATCH[1]}"   # show_
  first_num="${BASH_REMATCH[2]}"     # 003
elif [[ "$stem" =~ ^([0-9]+)$ ]]; then
  name_prefix=""
  first_num="${BASH_REMATCH[1]}"
else
  error "Could not find a number in the filename: ${BOLD}$filename${RESET}"
  error "Expected something like: video_001.ts, stream003.ts, 042.ts"
  exit 1
fi

pad_width="${#first_num}"   # number of digits → used for zero-padding
first_n=$((10#$first_num))  # decimal value of first number

header "⬇️   download-ts"
divider
info "First file : ${BOLD}$filename${RESET}"
info "Base URL   : ${BOLD}$base_url${RESET}"
info "Name prefix: ${BOLD}${name_prefix}${RESET}  number width: ${BOLD}${pad_width}${RESET}"

# ── Ask for last file number (or auto-detect) ─────────────────────────────
if [[ $AUTO -eq 1 ]]; then
  last_input=""
else
  echo
  printf "Last file number [Enter to auto-detect]: "
  read -r last_input
  last_input="${last_input// /}"
fi

if [[ -z "$last_input" ]]; then
  # Auto-detect: probe files via HEAD requests until server returns an error
  echo
  info "Auto-detecting last file..."
  n=$first_n
  last_n=$(( first_n - 1 ))
  while true; do
    padded="$(printf "%0${pad_width}d" $n)"
    url="${base_url}${name_prefix}${padded}${ext}"
    printf "  ${DIM}Probing %s ...${RESET} " "${name_prefix}${padded}${ext}"
    http_code="$(curl --silent --head --location --max-time 10       --retry 1 --write-out "%{http_code}" --output /dev/null "$url" 2>/dev/null || echo "000")"
    if [[ "$http_code" == "200" ]]; then
      echo -e "${GREEN}✔${RESET}  ${DIM}(${http_code})${RESET}"
      last_n=$n
      (( n++ )) || true
    else
      echo -e "${YELLOW}✖${RESET}  ${DIM}(${http_code}) — stopped${RESET}"
      break
    fi
  done

  if (( last_n < first_n )); then
    error "Could not reach even the first file. Check the URL."
    exit 1
  fi
  success "Detected last file: ${BOLD}$(printf "%0${pad_width}d" $last_n)${RESET}  ($(( last_n - first_n + 1 )) file(s))"
else
  # Manual entry — accept with or without leading zeros
  if [[ ! "$last_input" =~ ^[0-9]+$ ]]; then
    error "Please enter a number."
    exit 1
  fi
  last_n=$((10#$last_input))
  if (( last_n < first_n )); then
    error "Last number ($last_n) must be >= first number ($first_n)."
    exit 1
  fi
fi

total=$(( last_n - first_n + 1 ))

# ── Confirm output directory ───────────────────────────────────────────────
if [[ $AUTO -eq 1 ]]; then
  chosen_dir="$OUTPUT_DIR"
  mkdir -p "$chosen_dir"
else
  echo
  printf "Output directory [%s]: " "$OUTPUT_DIR"
  read -r chosen_dir
  chosen_dir="${chosen_dir:-$OUTPUT_DIR}"
  chosen_dir="${chosen_dir/#\~/$HOME}"

  if [[ ! -d "$chosen_dir" ]]; then
    printf "Directory does not exist. Create it? [y/N] "
    read -r make_dir
    if [[ "$make_dir" == "y" || "$make_dir" == "Y" ]]; then
      mkdir -p "$chosen_dir"
      success "Created: $chosen_dir"
    else
      error "Output directory unavailable. Aborting."
      exit 1
    fi
  fi
fi

# ── Summary before starting ────────────────────────────────────────────────
header "📋  Plan"
divider
info "Files to download : ${BOLD}$total${RESET}"
info "Range             : ${BOLD}$(printf "%0${pad_width}d" $first_n)${RESET} → ${BOLD}$(printf "%0${pad_width}d" $last_n)${RESET}"
info "Saving to         : ${BOLD}$chosen_dir${RESET}"
echo
if [[ $AUTO -eq 0 ]]; then
  printf "Start download? [Y/n] "
  read -r confirm
  if [[ "$confirm" == "n" || "$confirm" == "N" ]]; then
    info "Aborted."
    exit 0
  fi
fi

# ── Download loop ──────────────────────────────────────────────────────────
header "⬇️   Downloading"
divider

success_count=0
skip_count=0
fail_count=0

for (( n = first_n; n <= last_n; n++ )); do
  padded="$(printf "%0${pad_width}d" $n)"
  fname="${name_prefix}${padded}${ext}"
  url="${base_url}${fname}"
  dest="${chosen_dir}/${fname}"
  pos="$((n - first_n + 1))/$total"

  if [[ -f "$dest" ]]; then
    warn "[${pos}] Already exists, skipping: ${BOLD}$fname${RESET}"
    (( skip_count++ )) || true
    continue
  fi

  # Progress indicator on same line while downloading
  printf "${CYAN}⬇${RESET}  [${pos}] ${BOLD}%s${RESET} ... " "$fname"

  http_code=$(curl \
    --silent \
    --show-error \
    --fail \
    --location \
    --retry 3 \
    --retry-delay 2 \
    --output "$dest" \
    --write-out "%{http_code}" \
    "$url" 2>/dev/null) || true

  if [[ -f "$dest" && -s "$dest" ]]; then
    size="$(du -sh "$dest" | cut -f1)"
    echo -e "${GREEN}✔${RESET}  ${DIM}${size}${RESET}"
    (( success_count++ )) || true
  else
    echo -e "${RED}✖${RESET}  ${DIM}(HTTP ${http_code})${RESET}"
    rm -f "$dest"
    (( fail_count++ )) || true
  fi
done

# ── Summary ────────────────────────────────────────────────────────────────
header "📋  Done"
divider
[[ $success_count -gt 0 ]] && success "$success_count file(s) downloaded"
[[ $skip_count -gt 0 ]]    && info    "$skip_count file(s) skipped (already existed)"
[[ $fail_count -gt 0 ]]    && error   "$fail_count file(s) failed"

if (( success_count > 0 || skip_count > 0 )); then
  echo
  info "Files are in: ${BOLD}$chosen_dir${RESET}"
  info "Run ${BOLD}combine-ts${RESET} to merge them into an MP4."
fi
echo
